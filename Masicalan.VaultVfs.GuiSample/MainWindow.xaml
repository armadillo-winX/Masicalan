<Window x:Class="Masicalan.VaultVfs.GuiSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Masicalan.VaultVfs.GuiSample"
        mc:Ignorable="d"
        Title="Masicalan Vault VFS Manager (Sample)" Height="215" Width="566" ResizeMode="CanMinimize">
    <Grid>
        <Label Content="パス:" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="PathBox" 
                Margin="46,14,10,0" TextWrapping="NoWrap"
                MaxLines="1" Text="" VerticalAlignment="Top"/>
        <Button x:Name="CreateNewButton"
            Width="120" Height="24"
            Content="VFS の新規作成" HorizontalAlignment="Left" Margin="10,41,0,0" VerticalAlignment="Top" Click="CreateNewButtonOnClick"/>
        <Button x:Name="OpenButton"
            Content="VFS を開く" HorizontalAlignment="Left" Margin="10,70,0,0" VerticalAlignment="Top"
            Width="120" Height="24" Click="OpenButtonOnClick"/>
        <Button x:Name="AddScriptButton"
            Content="VFS にファイルを追加" HorizontalAlignment="Left" Margin="10,99,0,0" VerticalAlignment="Top"
            Width="120" Height="24" Click="AddScriptButtonOnClick"/>
        <ListBox x:Name="ScriptFilesListBox" Margin="135,66,10,10"/>
        <Button x:Name="EditButton"
            Width="45"
            Content="編集" HorizontalAlignment="Left" Margin="135,41,0,0" VerticalAlignment="Top" Click="EditButtonOnClick"/>
        <Button x:Name="DeleteButton"
            Width="45"
            Content="削除" HorizontalAlignment="Left" Margin="185,41,0,0" VerticalAlignment="Top" Click="DeleteButtonOnClick"/>
        <Button x:Name="ConvertButton"
            Content="ZIP に変換" HorizontalAlignment="Left" Margin="10,128,0,0" VerticalAlignment="Top" Width="120" Height="24" Click="ConvertButtonOnClick"/>

    </Grid>
</Window>

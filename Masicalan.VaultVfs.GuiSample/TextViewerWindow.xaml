<Window x:Class="Masicalan.VaultVfs.GuiSample.TextViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Masicalan.VaultVfs.GuiSample"
        mc:Ignorable="d"
        Title="Text Viewer" Height="278" Width="398"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <TextBox x:Name="MainTextBox"
            TextWrapping="NoWrap"
            AcceptsReturn="True"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto" Text="" Margin="10,10,10,39" FontFamily="MS Gothic"/>
        <Button x:Name="SaveButton"
            Width="90" Height="24"
            Content="保存" HorizontalAlignment="Right" Margin="0,0,10,10" VerticalAlignment="Bottom" Click="SaveButtonOnClick"/>
        <Label Content="属性(_A):" HorizontalAlignment="Left" Margin="10,0,0,6" VerticalAlignment="Bottom"/>
        <TextBlock x:Name="AttributeBlock"
            HorizontalAlignment="Left" Margin="67,0,0,11" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Bottom"/>

    </Grid>
</Window>
